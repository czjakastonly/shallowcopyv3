{
  "name": "@stonly/design-system",
  "version": "1.0.0",
  "description": "Stonly Design System - shared UI components and design tokens (vendored dist-only copy)",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./icons/*": {
      "import": "./dist/esm/ui/atoms/icons/*.js",
      "require": "./dist/cjs/ui/atoms/icons/*.cjs"
    },
    "./providers": {
      "import": "./dist/esm/ui/providers/index.js",
      "require": "./dist/cjs/ui/providers/index.cjs"
    }
  },
  "peerDependencies": {
    "react": "^16.10.2",
    "react-dom": "^16.10.2",
    "styled-components": "^6.1.19"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.0.1",
    "date-fns": "^2.24.0",
    "framer-motion": "3.2.1",
    "lodash": "^4.17.21",
    "react-textarea-autosize": "^8.5.3",
    "stylis": "^4.3.6",
    "stylis-plugin-rtl": "^2.1.1",
    "tabbable": "^6.2.0"
  }
}
